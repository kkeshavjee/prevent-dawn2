# PREVENT Dawn Backend Configuration

# Google API Key for Gemini LLM
GOOGLE_API_KEY=your_gemini_api_key_here

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
# SQLite (default for development):
DATABASE_URL=sqlite:///./prevent_auth.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/prevent_dawn

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# To enable Gmail SMTP:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification if not already enabled
# 3. Go to App Passwords: https://myaccount.google.com/apppasswords
# 4. Create a new App Password for "Mail" on "Other (Custom name)"
# 5. Copy the 16-character password (without spaces)

GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Legacy email settings (optional)
EMAIL_ENABLED=false
EMAIL_FROM=noreply@preventdawn.health

# ============================================
# SMS CONFIGURATION (Twilio)
# ============================================
# To enable Twilio SMS:
# 1. Sign up at https://www.twilio.com/try-twilio
# 2. Get your Account SID and Auth Token from Console
# 3. Get a Twilio phone number

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
